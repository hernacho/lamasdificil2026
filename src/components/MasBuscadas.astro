---
import { categories } from "../assets/constants/buscadas";
import ProductCard from "./ProductCard.astro";
import Icon from "../components/Icon.astro";
---

<section
  id="mas-buscadas"
  class="min-w-dvw my-4 flex flex-col items-center lg:items-start"
>
  <h2
    class="flex w-full h-20 items-center justify-center text-white bg-linear-to-b from-amber-950 to-amber-900 text-2xl lg:text-4xl"
  >
    Las más buscadas
  </h2>
  <div class="mx-auto flex max-w-screen flex-wrap justify-center">
    {
      categories.map((category) => (
        // Título de la sección
        <section class="carousel flex flex-col w-full">
          <h3 class=" text-center py-2 text-white bg-linear-to-b from-blue-900 to-blue-800 ">
            {category.title}
          </h3>
          {/* Contenedor externo */}
          <div class=" h-100 w-dvw justify-center flex items-center">
            <button class="bg-primary rounded-full w-12 h-12 items-center justify-center mx-2 hidden lg:flex carousel-prev">
              <Icon name="navigation" class="w-8 h-8 rotate-180 " />
            </button>
            <div class="carousel-viewport viewport overflow-x-auto w-[80dvw] scroll-smooth snap-x snap-mandatory scrollbar-hide">
              {/* Track */}
              <div class="carousel-track flex flex-nowrap transition-transform duration-300 w-max">
                {category.products.map((product, index) => (
                  <div
                    class="mx-2 lg:mx-4 snap-start"
                    style={`transition-delay: ${index * 150}ms`}
                  >
                    <ProductCard {...product} />
                  </div>
                ))}
              </div>
            </div>
            <button class="bg-primary rounded-full w-12 h-12 items-center justify-center mx-2 hidden lg:flex carousel-next">
              <Icon name="navigation" class="w-8 h-8 " />
            </button>
          </div>
        </section>
      ))
    }
  </div>
</section>

<script>
  const carousels = document.querySelectorAll(".carousel");

  carousels.forEach((carousel) => {
    const track = carousel.querySelector<HTMLElement>(".carousel-track");
    const viewport = carousel.querySelector<HTMLElement>(".carousel-viewport");

    const nextBtn = carousel.querySelector<HTMLButtonElement>(".carousel-next");
    const prevBtn = carousel.querySelector<HTMLButtonElement>(".carousel-prev");

    let currentIndex = 0;

    nextBtn?.addEventListener("click", () => {
      currentIndex++;
      updateCarousel();
    });

    prevBtn?.addEventListener("click", () => {
      currentIndex--;
      updateCarousel();
    });

    function updateCarousel() {
      if (!viewport || !track) return;
      const offset = currentIndex * viewport.clientWidth;

      track.style.transform = `translateX(-${offset}px)`;
    }

    const cards = track?.querySelectorAll(".card");
    const totalCards = cards?.length ?? 0;

    const maxIndex = Math.ceil(totalCards / 4) - 1;
  });
</script>

---
import { Image } from "astro:assets";
import { groups } from "../assets/constants/groups";
import Title from "../components/Title.astro";
import Icon from "../components/Icon.astro";
---

<section id="mundial" class="w-dvw">
  <Title title="Conocé los grupos del mundial" />

  <div
    class="w-full grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 p-4 relative"
  >
    {
      groups.map((group) => (
        <div>
          <h3>{group.id}</h3>
          <div class="flex flex-col justify-center border border-stone-500 rounded-sm shadow-md shadow-stone-600">
            {group.teams.map((team) => (
              <div>
                <div
                  class="cursor-pointer h-12 flex px-2 items-center"
                  data-team={team.name}
                >
                  <Image class="h-10" src={team.flag} alt={team.name} />
                  <p>{team.name}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))
    }
    <Icon
      id="group-click"
      name="click"
      class="absolute w-20 h-20 top-20 left-40 animate-pulse"
    />
  </div>
</section>

---
import { instagramPosts } from "../assets/constants/instagram.ts";
import Title from "./Title.astro";
import InstagramPost from "./InstagramPost.astro";
---

<section class="h-min-dvh instagram-swiper my-40">
  <Title title="Últimas publicaciones en Instagram" />
  <h3 class="text-center text-2xl py-4">
    Compartí tus fotos en Instagram junto a #lamasdificil
  </h3>
  <div class="swiper">
    <div class="swiper-wrapper">
      {
        instagramPosts.map((post) => (
          <div class="swiper-slide">
            <InstagramPost {...post} />
          </div>
        ))
      }
    </div>
    <div class="swiper-pagination"></div>
    <div class="swiper-button-next"></div>
    <div class="swiper-button-prev"></div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import {
    Navigation,
    Pagination,
    Autoplay,
    EffectCoverflow,
  } from "swiper/modules";

  const swiper = new Swiper(".swiper", {
    modules: [Navigation, Pagination, Autoplay, EffectCoverflow],
    slidesPerView: 1,
    spaceBetween: 16,
    centeredSlides: true,
    loop: true,
    effect: "coverflow",
    coverflowEffect: {
      rotate: 0,
      stretch: 1,
      depth: 120,
      scale: 0.9,
      modifier: 1,
      slideShadows: false,
    },
    pagination: {
      el: ".swiper-pagination",
      clickable: true,
    },
    autoplay: {
      delay: 3000,
      disableOnInteraction: false,
    },
    navigation: {
      nextEl: ".swiper-button-next",
      prevEl: ".swiper-button-prev",
    },
    breakpoints: {
      768: { slidesPerView: 2 },
      1024: { slidesPerView: 3 },
    },
  });
</script>

<style is:global>
  .swiper {
    width: 100%;
    height: 700px;
  }
  .instagram-swiper {
    overflow: visible;
  }

  .instagram-swiper .swiper-slide {
    display: flex;
    justify-content: center;
    filter: blur(2px);
    transition: filter 0.3s;
  }

  .instagram-swiper .swiper-slide-active {
    filter: blur(0);
  }

  @media (min-width: 1024px) {
    .swiper {
      width: 60%;
    }
  }
</style>

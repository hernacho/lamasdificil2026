---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section
    class="fixed top-20 h-[65dvh] lg:h-full min-w-dvw overflow-hidden lg:flex lg:flex-row lg:justify-center"
  >
    <div
      class="overflow-y-auto h-full pb-40 lg:w-[50dvw] lg:static"
      id="checkout-products"
    >
    </div>
    <div
      class="lg:my-2 w-full p-4 fixed bottom-6 lg:w-[40dvw] lg:h-80 lg:border lg:border-stone-500 lg:rounded-sm lg:static"
    >
      <div class="flex flex-col gap-4 lg:gap-10">
        <p class="text-xl mx-2">
          Productos en el carrito (<span id="checkout-count">0</span>)
        </p>
        <hr />
        <div class="flex justify-between px-4">
          <p class="text-2xl">Total</p>
          <p class="text-3xl font-semibold" id="checkout-total">$0</p>
        </div>
        <a
          href="#"
          class="flex w-auto mx-2 rounded-sm p-4 bg-blue-800 text-2xl justify-center text-white"
          >Finalizar compra</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  type CartItem = {
    id: string;
    name: string;
    price: string;
    image: string;
    quantity: number;
  };

  function renderCheckout() {
    const cartData = localStorage.getItem("cart") || "[]";
    const checkout: CartItem[] = JSON.parse(cartData);
    const cartProducts = document.getElementById("checkout-products");

    if (cartProducts) {
      cartProducts.innerHTML = checkout
        .map(
          (item) => `
        <div class="rounded-sm mx-auto my-2 lg:p-2 p-4 flex flex-col bg-white w-11/12 h-fit border border-stone-400 lg:h-48 lg:mx-2">
          <div class="flex gap-4 px-2">
            <img src="${item.image}" alt="${item.name}" class="lg:h-40 lg:w-auto w-24" />
            <div class="flex flex-col gap-10 w-full lg:gap-6 lg:px-10">
              <p class="text-2xl lg:text-xl">${item.name}</p>
              <p class="text-4xl lg:text-2xl font-semibold">$${item.price}</p>
              <div class="lg:flex lg:justify-between lg:w-full">
                <div class="flex w-full px-4 gap-2 lg:px-0 lg:items-center">
                  <button data-action="decrease" data-id="${item.id}" class="flex items-center justify-center w-6 h-6 bg-stone-400 rounded-sm text-2xl">-</button>
                  <input class="border-stone-500 w-10 border text-center rounded-sm" type="number" value="${item.quantity}" />
                  <button data-action="increase" data-id="${item.id}" class="flex items-center justify-center w-6 h-6 bg-stone-400 rounded-sm text-2xl">+</button>
                </div>
                <button data-action="delete" data-id="${item.id}" class="w-full flex justify-end">
                  <svg width="32" height="32" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg">
                    <path d="M667.8 362.1H304V830c0 28.2 23 51 51.3 51h312.4c28.4 0 51.4-22.8 51.4-51V362.2h-51.3z" fill="#CCCCCC" />
                    <path d="M750.3 295.2c0-8.9-7.6-16.1-17-16.1H289.9c-9.4 0-17 7.2-17 16.1v50.9c0 8.9 7.6 16.1 17 16.1h443.4c9.4 0 17-7.2 17-16.1v-50.9z" fill="#CCCCCC" />
                    <path d="M733.3 258.3H626.6V196c0-11.5-9.3-20.8-20.8-20.8H419.1c-11.5 0-20.8 9.3-20.8 20.8v62.3H289.9c-20.8 0-37.7 16.5-37.7 36.8V346c0 18.1 13.5 33.1 31.1 36.2V830c0 39.6 32.3 71.8 72.1 71.8h312.4c39.8 0 72.1-32.2 72.1-71.8V382.2c17.7-3.1 31.1-18.1 31.1-36.2v-50.9c0.1-20.2-16.9-36.8-37.7-36.8z m-293.5-41.5h145.3v41.5H439.8v-41.5z m-146.2 83.1H729.5v41.5H293.6v-41.5z m404.8 530.2c0 16.7-13.7 30.3-30.6 30.3H355.4c-16.9 0-30.6-13.6-30.6-30.3V382.9h373.6v447.2z" fill="#211F1E" />
                    <path d="M511.6 798.9c11.5 0 20.8-9.3 20.8-20.8V466.8c0-11.5-9.3-20.8-20.8-20.8s-20.8 9.3-20.8 20.8v311.4c0 11.4 9.3 20.7 20.8 20.7zM407.8 798.9c11.5 0 20.8-9.3 20.8-20.8V466.8c0-11.5-9.3-20.8-20.8-20.8s-20.8 9.3-20.8 20.8v311.4c0.1 11.4 9.4 20.7 20.8 20.7zM615.4 799.6c11.5 0 20.8-9.3 20.8-20.8V467.4c0-11.5-9.3-20.8-20.8-20.8s-20.8 9.3-20.8 20.8v311.4c0 11.5 9.3 20.8 20.8 20.8z" fill="#211F1E" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      `,
        )
        .join("");

      // Actualizar total y cantidad
      const total = checkout.reduce(
        (sum, item) => sum + Number(item.price) * item.quantity,
        0,
      );
      const count = checkout.reduce((sum, item) => sum + item.quantity, 0);
      document.getElementById("checkout-total")!.textContent = `$${total}`;
      document.getElementById("checkout-count")!.textContent = String(count);

      cartProducts
        .querySelectorAll("[data-action]")
        .forEach((button: Element) => {
          button.addEventListener("click", () => {
            const id = (button as HTMLElement).dataset.id;
            const action = (button as HTMLElement).dataset.action;
            updateCheckout(id!, action!);
          });
        });
    }
  }

  renderCheckout();

  function updateCheckout(id: string, action: string) {
    const cartData = localStorage.getItem("cart") || "[]";
    let cart: CartItem[] = JSON.parse(cartData);

    if (action === "increase") {
      cart = cart.map((item) =>
        item.id === id ? { ...item, quantity: item.quantity + 1 } : item,
      );
    } else if (action === "decrease") {
      cart = cart.map((item) =>
        item.id === id
          ? { ...item, quantity: Math.max(1, item.quantity - 1) }
          : item,
      );
    } else if (action === "delete") {
      cart = cart.filter((item) => item.id !== id);
    }

    localStorage.setItem("cart", JSON.stringify(cart));
    renderCheckout();
  }
</script>
